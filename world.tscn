[sub_resource type="GDScript" id="GDScript_ioo17"]
script/source = "extends Node

var active_tool = \"trees\"

var tree_tool
var grass_tool


func _ready():

	tree_tool = get_parent().get_node(\"ZonePainter\")
	grass_tool = get_parent().get_node(\"GrassPainter\")

	set_tool(\"trees\")


func _input(event):

	if event is InputEventKey and event.pressed:

		if event.keycode == KEY_1:
			set_tool(\"trees\")

		if event.keycode == KEY_2:
			set_tool(\"grass\")


func set_tool(tool):

	active_tool = tool

	tree_tool.set_process_unhandled_input(tool == \"trees\")
	grass_tool.set_process_unhandled_input(tool == \"grass\")

	print(\"Active tool:\", tool)
"

