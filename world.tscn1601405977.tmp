[sub_resource type="GDScript" id="GDScript_gbfbk"]
script/source = "extends Node3D

@export var brush_radius := 12.0
@export var tree_density := 0.008
@export var tree_spacing := 4.0

var camera : Camera3D
var painting := false

var tool := \"trees\"

@onready var player = get_node(\"../CharacterBody3D\")

@onready var TreeGenerator = preload(\"res://TreeGenerator.gd\").new()
@onready var TreeSaveManager = preload(\"res://TreeSaveManager.gd\").new()


func _ready():

	camera = get_viewport().get_camera_3d()


func _input(event):

	if event is InputEventKey and event.pressed:

		if event.keycode == KEY_F1:
			var node = get_node(\"../RoadsSmooth\")
			node.visible = !node.visible

		if event.keycode == KEY_F2:
			var node = get_node(\"../RoadsSmooth\")
			node.visible = !node.visible

	# Disable painting controls if not flying
	if !player.is_flying:
		painting = false
		return

	if event is InputEventMouseButton:

		# LEFT CLICK = PAINT
		if event.button_index == MOUSE_BUTTON_LEFT:
			painting = event.pressed

		# RIGHT CLICK = ERASE
		if event.button_index == MOUSE_BUTTON_RIGHT and event.pressed:

			var pos = get_crosshair_ground()

			if pos != null:
				erase_trees(pos)

		# SCROLL UP
		if event.button_index == MOUSE_BUTTON_WHEEL_UP:
			brush_radius += 2.0

		# SCROLL DOWN
		if event.button_index == MOUSE_BUTTON_WHEEL_DOWN:
			brush_radius = max(2.0, brush_radius - 2.0)


func _process(delta):

	if tool != \"trees\":
		return

	var pos = get_crosshair_ground()

	if pos != null:

		if painting:
			paint_trees(pos)


# -------------------------------------------------
# Crosshair Raycast
# -------------------------------------------------

func get_crosshair_ground():

	if camera == null:
		return null

	var viewport = get_viewport()
	var center = viewport.get_visible_rect().size / 2

	var ray_origin = camera.project_ray_origin(center)
	var ray_dir = camera.project_ray_normal(center)

	var space = get_world_3d().direct_space_state

	var query = PhysicsRayQueryParameters3D.create(
		ray_origin,
		ray_origin + ray_dir * 2000
	)

	var result = space.intersect_ray(query)

	if result:
		return result.position

	return null


# -------------------------------------------------
# Tree Painting
# -------------------------------------------------

func paint_trees(center):

	var tree_container = get_parent().get_node_or_null(\"Trees\")

	if tree_container == null:
		return

	var area = PI * brush_radius * brush_radius
	var tree_count = int(area * tree_density)

	var created := false

	for i in range(tree_count):

		var angle = randf() * TAU
		var dist = sqrt(randf()) * brush_radius

		var offset = Vector3(
			cos(angle) * dist,
			0,
			sin(angle) * dist
		)

		var pos = center + offset

		# TREE SPACING CHECK
		var too_close := false

		for tree in tree_container.get_children():

			if tree.global_position.distance_to(pos) < tree_spacing:
				too_close = true
				break

		if too_close:
			continue

		TreeGenerator.create_tree(
			tree_container,
			pos.x,
			pos.z,
			null
		)

		created = true

	# Save trees after painting
	if created:
		TreeSaveManager.save_trees(tree_container)


# -------------------------------------------------
# Tree Eraser
# -------------------------------------------------

func erase_trees(center):

	var tree_container = get_parent().get_node_or_null(\"Trees\")

	if tree_container == null:
		return

	var erased := false

	for tree in tree_container.get_children():

		var dist = tree.global_position.distance_to(center)

		if dist <= brush_radius:
			tree.queue_free()
			erased = true

	# Save after deleting
	if erased:
		TreeSaveManager.save_trees(tree_container)
"

[sub_resource type="StyleBoxFlat" id="StyleBoxFlat_tlwt5"]
